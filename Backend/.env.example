# Environment
NODE_ENV=development
PORT=3001

# JWT Configuration
JWT_SECRET=your_jwt_secret_here_change_this_in_production
JWT_EXPIRES_IN=24h

# Smart Contract
HOLDIS_CONTRACT_ADDRESS=0xYourContractAddress

# Blockradar Configuration (Wallet-as-a-Service)
BLOCKRADAR_API_KEY=your_blockradar_api_key_here
BLOCKRADAR_API_URL=https://api.blockradar.co
BLOCKRADAR_WALLET_ID=your_wallet_id_here
BLOCKRADAR_WEBHOOK_SECRET=your_webhook_secret_here

# Multi-Chain Wallet IDs (Get UUIDs from Blockradar Dashboard → Wallets)
# Each wallet ID is the UUID shown in the wallet details page
BLOCKRADAR_WALLET_ID_BASE=your_base_wallet_id_here
BLOCKRADAR_WALLET_ID_ETHEREUM=your_ethereum_wallet_id_here
BLOCKRADAR_WALLET_ID_POLYGON=your_polygon_wallet_id_here
BLOCKRADAR_WALLET_ID_BNB=your_bnb_wallet_id_here
BLOCKRADAR_WALLET_ID_ARBITRUM=your_arbitrum_wallet_id_here
BLOCKRADAR_WALLET_ID_OPTIMISM=your_optimism_wallet_id_here
BLOCKRADAR_WALLET_ID_TRON=your_tron_wallet_id_here
BLOCKRADAR_WALLET_ID_SOLANA=your_solana_wallet_id_here

# Database - Supabase (PostgreSQL + Auth + Storage)
DATABASE_URL=postgresql://postgres:password@host:5432/postgres
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Blockchain RPC (Alchemy recommended)
ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key

# Platform Configuration
PLATFORM_FEE_PERCENTAGE=2.5
MIN_GAS_BALANCE_ETH=0.1
PLATFORM_WALLET_ADDRESS=0xYourPlatformWalletAddress

# Email Configuration
EMAIL_ENABLED=true
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@yourdomain.com

# SendGrid (Get API key from: https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Mailgun (Alternative email provider)
MAILGUN_SMTP_HOST=smtp.mailgun.org
MAILGUN_SMTP_USER=your_mailgun_smtp_user
MAILGUN_SMTP_PASSWORD=your_mailgun_smtp_password

# SMTP (Generic SMTP configuration)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin Setup (for create-admin script)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_WALLET_ADDRESS=0xYourMasterWalletAddress
